}

inline std::string tos(double a_value)
{
  std::string _s;
  sprintf(_s, 32, "%g", a_value);
  return _s;
}

inline std::string tos(bool a_value)
{
  return std::string(a_value ? "true" : "false");
}

inline std::string tos(const std::string& a_value)
{
  return a_value;
}

template<class T>
inline std::string tos(const std::vector<T>& a_vals, const std::string& a_sep = "\n")
{
  if (a_vals.empty()) return "";
  std::string result;
  bool first = true;
  for (const auto& val : a_vals)
  {
    if (!first) result += a_sep;
    first = false;
    result += tos(val);
  }
  return result;
}

}  // namespace tools

#endif
