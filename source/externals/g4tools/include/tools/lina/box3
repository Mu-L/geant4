#ifndef tools_box3
#define tools_box3

#include "../mnmx"
#include "vec"

#include <cmath>
#include <limits>

namespace tools
{

template<class T>
class box3
{
  public:

    using VEC3 = vec3<T>;

  public:

    box3() { make_empty(); }
    ~box3() = default;

    box3(const box3& a_from) = default;
    box3& operator=(const box3& a_from) = default;

    bool center(VEC3& a_center) const
    {
      if (is_empty())
      {
        a_center.set_value(0, 0, 0);
        return false;
      }  //??
      a_center.set_value((m_max[0] + m_min[0]) / T(2), (m_max[1] + m_min[1]) / T(2),
                         (m_max[2] + m_min[2]) / T(2));
      return true;
    }

    bool set_bounds(const VEC3& a_mn, const VEC3& a_mx)
    {
      if (a_mn[0] > a_mx[0] || a_mn[1] > a_mx[1] || a_mn[2] > a_mx[2]) return false;
      m_min = a_mn;
      m_max = a_mx;
      return true;
    }

    bool get_size(T& a_dx, T& a_dy, T& a_dz) const
    {
      if (is_empty())
      {
        a_dx = 0;
        a_dy = 0;
        a_dz = 0;
        return false;
      }
      a_dx = m_max[0] - m_min[0];
      a_dy = m_max[1] - m_min[1];
      a_dz = m_max[2] - m_min[2];
      return true;
    }

    void make_empty()
    {
      constexpr T max_val = std::numeric_limits<T>::max();
      m_min.set_value(max_val, max_val, max_val);
      m_max.set_value(-max_val, -max_val, -max_val);
    }

    bool is_empty() const { return m_max[0] < m_min[0]; }

    const VEC3& min() const { return m_min; }
    const VEC3& max() const { return m_max; }

    void extend_by(const VEC3& a_point)
    {
      // Extend the boundaries of the box by the given point, i.e. make the
      // point fit inside the box if it isn't already so.
      if (is_empty())
      {
        set_bounds(a_point, a_point);
      }
      else
      {
        m_min.set_value(min_of<T>(a_point[0], m_min[0]), min_of<T>(a_point[1], m_min[1]),
                        min_of<T>(a_point[2], m_min[2]));
        m_max.set_value(max_of<T>(a_point[0], m_max[0]), max_of<T>(a_point[1], m_max[1]),
                        max_of<T>(a_point[2], m_max[2]));
      }
    }

    void extend_by(T a_x, T a_y, T a_z)
    {
      // Extend the boundaries of the box by the given point, i.e. make the
      // point fit inside the box if it isn't already so.
      extend_by({a_x, a_y, a_z});
    }

  private:

    static T zero() { return T(); }

  private:

    VEC3 m_min;
    VEC3 m_max;
};

// Backward compatibility/specialization for float
using box3f = box3<float>;

// optimization (used in exlib/sg/text_hershey) :
inline void box_3f_make_empty(float& a_mn_x, float& a_mn_y, float& a_mn_z, float& a_mx_x,
                              float& a_mx_y, float& a_mx_z)
{
  a_mn_x = std::numeric_limits<float>::max();
  a_mn_y = std::numeric_limits<float>::max();
  a_mn_z = std::numeric_limits<float>::max();
  a_mx_x = std::numeric_limits<float>::lowest();
  a_mx_y = std::numeric_limits<float>::lowest();
  a_mx_z = std::numeric_limits<float>::lowest();
}

inline void box_3f_extend_by(float& a_mn_x, float& a_mn_y, float& a_mn_z, float& a_mx_x,
                             float& a_mx_y, float& a_mx_z, float a_x, float a_y, float a_z)
{
  if (a_mx_x < a_mn_x)
  {  // is empty.
    a_mn_x = a_x;
    a_mn_y = a_y;
    a_mn_z = a_z;

    a_mx_x = a_x;
    a_mx_y = a_y;
    a_mx_z = a_z;
  }
  else
  {
    a_mn_x = min_of<float>(a_x, a_mn_x);
    a_mn_y = min_of<float>(a_y, a_mn_y);
    a_mn_z = min_of<float>(a_z, a_mn_z);

    a_mx_x = max_of<float>(a_x, a_mx_x);
    a_mx_y = max_of<float>(a_y, a_mx_y);
    a_mx_z = max_of<float>(a_z, a_mx_z);
  }
}

}  // namespace tools

#endif
